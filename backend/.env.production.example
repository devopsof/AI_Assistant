# ── Application ────────────────────────────────────────────
APP_ENV=production

# ── Auth ───────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_VALUE
AUTH_ENABLED=true

# ── CORS ───────────────────────────────────────────────────
# Your CloudFront distribution domain or ALB URL
ALLOWED_ORIGINS=https://your-cloudfront-domain.cloudfront.net

# ── Storage ────────────────────────────────────────────────
STORAGE_MODE=s3
S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in production.
# Use an IAM task role on the ECS task definition instead.

# ── Vector DB ──────────────────────────────────────────────
CHROMA_HOST=your-chromadb-service-hostname
CHROMA_PORT=8000

# ── LLM ────────────────────────────────────────────────────
# Pull from AWS Secrets Manager in production, not this file
GROQ_API_KEY=PULL_FROM_SECRETS_MANAGER
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# ── Rate limiting ──────────────────────────────────────────
REDIS_URL=redis://your-elasticache-endpoint:6379

# ── Tuning ─────────────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_UPLOAD_MB=20
RATE_LIMIT_ENABLED=true
